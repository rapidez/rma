{
    "name": "rapidez/rma",
    "description": "MageOS_RMA compatibility",
    "keywords": [
        "rapidez",
        "rma"
    ],
    "homepage": "https://github.com/rapidez/rma",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Roy Duineveld",
            "email": "royduineveld@gmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "rapidez/core": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Rapidez\\RMA\\": "src"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rapidez\\RMA\\RMAServiceProvider"
            ]
        }
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "rapidez/coding-standards": "^1.0"
    }
}
